{
  "name": "quartermaster-mcp",
  "version": "0.1.1",
  "description": "Offline, zero-config MCP proxy: federate N downstream servers behind one ranked retrieve_tools. Self-contained — no embedding model, no network.",
  "type": "module",
  "bin": {
    "quartermaster-mcp": "./bin/quartermaster-mcp.js"
  },
  "files": ["dist/index.js", "bin", "README.md"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node22 --external:@modelcontextprotocol/sdk --external:@modelcontextprotocol/sdk/* --outfile=dist/index.js",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["mcp", "model-context-protocol", "proxy", "gateway", "tool-router", "tool-selection", "tool-retrieval", "bm25", "offline", "agents"],
  "license": "MIT",
  "author": "Pranav Nagrecha",
  "repository": {
    "type": "git",
    "url": "github:PranavNagrecha/quartermaster",
    "directory": "packages/proxy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@quartermaster/core": "workspace:^",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
