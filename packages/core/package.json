  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tool-router",
    "tool-selection",
    "tool-retrieval",
    "bm25",
    "tf-idf",
    "offline",
    "zero-dependency",
    "llm",
    "agents"
  ],
  "license": "MIT",
  "author": "Pranav Nagrecha",
  "repository": {
    "type": "git",
    "url": "github:PranavNagrecha/quartermaster",
