{
  "name": "@quartermaster/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Quartermaster CLI — eval, dashboard, report, and inspect for MCP tool routing.",
  "type": "module",
  "bin": {
    "quartermaster": "./bin/quartermaster.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "license": "MIT",
  "author": "Pranav Nagrecha",
  "repository": {
    "type": "git",
    "url": "github:PranavNagrecha/quartermaster",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@quartermaster/core": "workspace:^",
    "@quartermaster/policy": "workspace:^",
    "@quartermaster/telemetry": "workspace:^",
    "quartermaster-mcp": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
